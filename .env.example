# Supabase — primary storage backend (required)
SUPABASE_URL=                 # https://xxx.supabase.co
SUPABASE_KEY=                 # service role key (eyJ...)
# SUPABASE_SERVICE_ROLE_KEY=  # alias for SUPABASE_KEY

# BrightMatter API
BRIGHTMATTER_API_KEY=         # API key for authenticating callers
BRIGHTMATTER_HOST=0.0.0.0
BRIGHTMATTER_PORT=8100

# BigQuery — Tier 2: historical ad data ingestion (optional)
BIGQUERY_CREDENTIALS_JSON=    # inline JSON string of service account
# GOOGLE_APPLICATION_CREDENTIALS=  # alternative: path to service account JSON file

# Airtable — Tier 3: pattern publishing (optional)
AIRTABLE_API_KEY=             # Personal Access Token (pat...)
AIRTABLE_BASE_ID=             # default: appfuhAEXKZBKcDLi (MH-OS ops base)

# Anthropic — for LLM features (optional)
ANTHROPIC_API_KEY=

# Firebase — legacy fallback (deprecated)
# FIREBASE_CREDENTIALS_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_CLOUD_PROJECT=
