# Supabase — preferred storage backend (set both to enable)
SUPABASE_URL=                 # https://xxx.supabase.co
SUPABASE_KEY=                 # service role key (eyJ...)
# SUPABASE_SERVICE_ROLE_KEY=  # alias for SUPABASE_KEY

# Firebase — fallback when SUPABASE_URL is not set
FIREBASE_CREDENTIALS_JSON=    # inline JSON string of service account
GOOGLE_APPLICATION_CREDENTIALS=  # path to service account JSON file
GOOGLE_CLOUD_PROJECT=         # project ID (auto-extracted from SA if omitted)

# BrightMatter API
BRIGHTMATTER_API_KEY=         # API key for authenticating callers
BRIGHTMATTER_HOST=0.0.0.0
BRIGHTMATTER_PORT=8100
