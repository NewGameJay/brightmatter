      "seed": 638373813,
      "version": 1,
      "versionNonce": 1571179067,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "events           \u2014 normalized event stream from all platforms\noutcomes         \u2014 approve/deny + post-action results\nguidance_cache   \u2014 precomputed advisor output (per skill + client)\npatterns         \u2014 learned patterns (mirror of semantic memory)\n\nCron worker every 5 min:\n  pull events \u2192 create episodes \u2192 consolidate \u2192 refresh cache\n  check for new improvement proposals",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "events           \u2014 normalized event stream from all platforms\noutcomes         \u2014 approve/deny + post-action results\nguidance_cache   \u2014 precomputed advisor output (per skill + client)\npatterns         \u2014 learned patterns (mirror of semantic memory)\n\nCron worker every 5 min:\n  pull events \u2192 create episodes \u2192 consolidate \u2192 refresh cache\n  check for new improvement proposals",
      "lineHeight": 1.25,
      "autoResize": true
    },
