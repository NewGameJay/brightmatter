      "versionNonce": 601877720,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "6-step nightly cycle: (1) decay (2) consolidate\n(3) archive stale (4) promote to procedural\n(5) TTL cleanup (6) procedural decay.\nContext-aware splitting when context explains\n>30% of variance. Trajectory points for multi-\ncheckpoint strategies.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "6-step nightly cycle: (1) decay (2) consolidate\n(3) archive stale (4) promote to procedural\n(5) TTL cleanup (6) procedural decay.\nContext-aware splitting when context explains\n>30% of variance. Trajectory points for multi-\ncheckpoint strategies.",
      "lineHeight": 1.25,
      "autoResize": true
    },
