      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "get_guidance(skill, tenant, domain, context)        \u2192  Guidance{parameters, confidence, source}\nregister_prediction(skill, tenant, domain, ...)     \u2192  prediction_id\nrecord_outcome(prediction_id, observed, goal)       \u2192  LearningResult\nscore(domain, event, context)                       \u2192  ScoringResult\nrun_consolidation(tenant_id)                        \u2192  consolidation stats\nrecord_user_feedback(prediction_id, rating, ...)    \u2192  pattern confidence updates",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "get_guidance(skill, tenant, domain, context)        \u2192  Guidance{parameters, confidence, source}\nregister_prediction(skill, tenant, domain, ...)     \u2192  prediction_id\nrecord_outcome(prediction_id, observed, goal)       \u2192  LearningResult\nscore(domain, event, context)                       \u2192  ScoringResult\nrun_consolidation(tenant_id)                        \u2192  consolidation stats\nrecord_user_feedback(prediction_id, rating, ...)    \u2192  pattern confidence updates",
      "lineHeight": 1.25,
      "autoResize": true
    },
