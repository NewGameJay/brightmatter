      "boundElements": [],
      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "Firebase: system/intelligence/semantic/{domain}/patterns\nBayesian: \u03b1 = prior\u00d710 + wins,  \u03b2 = (1-prior)\u00d710 + losses\nEMA expected value. Decay 0.99/day. <0.1 conf +\n5 evidence \u2192 archived. Jaccard + LLM similarity.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Firebase: system/intelligence/semantic/{domain}/patterns\nBayesian: \u03b1 = prior\u00d710 + wins,  \u03b2 = (1-prior)\u00d710 + losses\nEMA expected value. Decay 0.99/day. <0.1 conf +\n5 evidence \u2192 archived. Jaccard + LLM similarity.",
      "lineHeight": 1.25,
      "autoResize": true
    },
