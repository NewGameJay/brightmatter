      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "The regression test. Curated benchmark datasets.\nMetrics: prediction_error, success_rate, segment_\naccuracy vs thresholds. Rolls back shadow promotions\nthat fail benchmarks. brain_benchmarks.yaml config.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
