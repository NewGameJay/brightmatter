      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "The student. Bayesian updates on each outcome.\nDrift detection: mean-diff of older vs recent error\n> 2\u03c3 \u2192 reset confidence. Trajectory-aware error\nagainst checkpoint target. Weighted by Three-Gate.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The student. Bayesian updates on each outcome.\nDrift detection: mean-diff of older vs recent error\n> 2\u03c3 \u2192 reset confidence. Trajectory-aware error\nagainst checkpoint target. Weighted by Three-Gate.",
      "lineHeight": 1.25,
      "autoResize": true
    },
