    {
      "id": "6h0w064w3u1hbj6t",
      "type": "text",
      "x": 1730,
      "y": 3318,
      "width": 1500,
      "height": 104,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
