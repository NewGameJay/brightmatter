      "boundElements": [],
      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "When the diary shows\nthe same thing repeatedly,\nit becomes a pattern:\n\n\"This usually works for\nthis kind of client.\"",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When the diary shows\nthe same thing repeatedly,\nit becomes a pattern:\n\n\"This usually works for\nthis kind of client.\"",
      "lineHeight": 1.25,
      "autoResize": true
    },
