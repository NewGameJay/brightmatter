      "boundElements": [],
      "updated": 1713283200000,
      "link": null,
      "locked": false,
      "text": "When a pattern holds true\nacross many different skills,\nit graduates to wisdom:\n\n\"Mornings beat afternoons,\nfor most things.\"",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When a pattern holds true\nacross many different skills,\nit graduates to wisdom:\n\n\"Mornings beat afternoons,\nfor most things.\"",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "id": "tny79mvf8kfqwwhg",
